{
  "name": "@kirby/cli-wterm-host",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "nx": {
    "name": "cli-wterm-host",
    "targets": {
      "build-server": {
        "executor": "@nx/esbuild:esbuild",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "platform": "node",
          "outputPath": "apps/cli-wterm-host/dist",
          "format": [
            "esm"
          ],
          "bundle": true,
          "external": [
            "node-pty",
            "ws"
          ],
          "main": "apps/cli-wterm-host/src/main.ts",
          "tsConfig": "apps/cli-wterm-host/tsconfig.app.json",
          "assets": [
            "apps/cli-wterm-host/src/assets"
          ],
          "esbuildOptions": {
            "sourcemap": true,
            "outExtension": {
              ".js": ".js"
            }
          }
        }
      },
      "build-client": {
        "executor": "nx:run-commands",
        "outputs": [
          "{projectRoot}/dist/public"
        ],
        "options": {
          "command": "node build-client.mjs",
          "cwd": "apps/cli-wterm-host"
        }
      },
      "build": {
        "executor": "nx:noop",
        "dependsOn": [
          "build-server",
          "build-client"
        ]
      },
      "serve": {
        "continuous": true,
        "dependsOn": [
          "build",
          {
            "projects": [
              "cli"
            ],
            "target": "build"
          }
        ],
        "executor": "nx:run-commands",
        "options": {
          "command": "node apps/cli-wterm-host/dist/main.js"
        }
      }
    }
  },
  "dependencies": {
    "@wterm/dom": "0.1.9",
    "node-pty": "^1.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.12"
  }
}
