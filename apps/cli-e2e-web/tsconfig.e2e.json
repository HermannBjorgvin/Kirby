{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "outDir": "out-tsc/playwright",
    "sourceMap": false,
    "lib": ["es2022", "dom"],
    "types": ["node"]
  },
  "include": ["**/*.ts", "**/*.js", "playwright.config.ts"],
  "exclude": [
    "out-tsc",
    "test-output",
    "test-results",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs"
  ]
}
