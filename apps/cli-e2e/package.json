{
  "name": "@kirby/cli-e2e",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "nx": {
    "name": "cli-e2e",
    "targets": {
      "//": "e2e target temporarily disabled — parity held by cli-e2e-web (Playwright+wterm). Tests under src/ are kept on disk for reference during the migration; restore the target below to re-enable.",
      "//e2e": {
        "dependsOn": [
          {
            "projects": [
              "cli"
            ],
            "target": "build"
          }
        ],
        "executor": "nx:run-commands",
        "options": {
          "command": "env -u CI -u CONTINUOUS_INTEGRATION -u GITHUB_ACTIONS npx @microsoft/tui-test",
          "cwd": "apps/cli-e2e"
        },
        "cache": false
      }
    }
  }
}
