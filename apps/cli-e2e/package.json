{
  "name": "@kirby/cli-e2e",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "nx": {
    "name": "cli-e2e",
    "tags": ["type:app", "scope:cli-e2e"],
    "targets": {
      "e2e": {
        "dependsOn": [
          {
            "projects": [
              "cli"
            ],
            "target": "build"
          }
        ],
        "executor": "nx:run-commands",
        "options": {
          "command": "env -u CI -u CONTINUOUS_INTEGRATION -u GITHUB_ACTIONS npx @microsoft/tui-test",
          "cwd": "apps/cli-e2e"
        },
        "cache": false
      }
    }
  }
}
